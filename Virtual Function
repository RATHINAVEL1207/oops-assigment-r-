#include <iostream>
using namespace std;

// Base Class
class Shape {
public:
    virtual void area() {
        cout << "Calculating area of shape" << endl;
    }
};

// Derived Class 1
class Rectangle : public Shape {
private:
    int length, width;

public:
    Rectangle(int l, int w) {
        length = l;
        width = w;
    }

    void area() {
        cout << "Area of Rectangle = " << length * width << endl;
    }
};

// Derived Class 2
class Circle : public Shape {
private:
    float radius;

public:
    Circle(float r) {
        radius = r;
    }

    void area() {
        cout << "Area of Circle = " << 3.14 * radius * radius << endl;
    }
};

int main() {
    Shape* s;  // Base class pointer

    Rectangle r(10, 5);
    Circle c(7);

    s = &r;
    s->area();   // Calls Rectangle's area()

    s = &c;
    s->area();   // Calls Circle's area()

    return 0;
}
