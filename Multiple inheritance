#include <iostream>
using namespace std;

class Marks {
protected:
    int m1, m2;
public:
    Marks(int a, int b) : m1(a), m2(b) {}
};

class Sports {
protected:
    int score;
public:
    Sports(int s) : score(s) {}
};

class Result : public Marks, public Sports {
public:
    Result(int a, int b, int s) : Marks(a, b), Sports(s) {}

    void display() {
        int total = m1 + m2 + score;
        cout << "Academic Marks: " << m1 + m2 << endl;
        cout << "Sports Score: " << score << endl;
        cout << "Total Score: " << total << endl;
    }
};

int main() {
    Result r(80, 85, 20);
    r.display();
    return 0;
}
